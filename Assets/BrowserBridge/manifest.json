{
  "manifest_version": 3,
  "name": "CquAutoLogin Browser Bridge",
  "version": "1.0.1",
  "description": "Reports only the visible authentication state of the configured portal.",
  "key": "",
  "permissions": [
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://atrust.cqu.edu.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://atrust.cqu.edu.cn/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "CquAutoLogin browser bridge"
  }
}
